generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum FundType {
  DEPOSIT
  EXPENSE
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  username   String   @unique
  password   String
  role       Role     @default(USER)
  signRole   String?
  stampImage String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  approvals           Approval[]
  resolutionApprovals ResolutionApproval[]
}

model BudgetCategory {
  id        Int      @id @default(autoincrement())
  fundType  FundType
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  budgets     Budget[]
  documents   Document[]
  resolutions Resolution[]
  preExpenses PreExpense[]

  @@unique([fundType, name])
}

model Budget {
  id         Int            @id @default(autoincrement())
  year       Int
  amount     BigInt         @default(0)
  categoryId Int
  category   BudgetCategory @relation(fields: [categoryId], references: [id])
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([year, categoryId])
}

model BudgetHistory {
  id         Int      @id @default(autoincrement())
  year       Int
  categoryId Int
  oldAmount  BigInt
  newAmount  BigInt
  changedBy  String
  changedAt  DateTime @default(now())
}

model Document {
  id          Int            @id @default(autoincrement())
  docNumber   String         @unique
  year        Int
  month       Int
  monthSeq    Int
  fundType    FundType
  categoryId  Int
  category    BudgetCategory @relation(fields: [categoryId], references: [id])
  title       String
  expenseName String
  amount      BigInt
  remark      String?        @db.Text
  author      String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  approvals  Approval[]
  resolution Resolution?
}

model Approval {
  id         Int       @id @default(autoincrement())
  documentId Int
  document   Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     Int?
  user       User?     @relation(fields: [userId], references: [id])
  role       String
  signature  String?   @db.Text
  signedAt   DateTime?
  createdAt  DateTime  @default(now())

  @@unique([documentId, role])
}

model Resolution {
  id           Int            @id @default(autoincrement())
  documentId   Int            @unique
  document     Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  resNumber    String         @unique
  actualAmount BigInt
  remark       String?        @db.Text
  author       String
  categoryId   Int
  category     BudgetCategory @relation(fields: [categoryId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  approvals ResolutionApproval[]
}

model ResolutionApproval {
  id           Int        @id @default(autoincrement())
  resolutionId Int
  resolution   Resolution @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  userId       Int?
  user         User?      @relation(fields: [userId], references: [id])
  role         String
  signature    String?    @db.Text
  signedAt     DateTime?
  createdAt    DateTime   @default(now())

  @@unique([resolutionId, role])
}

model PreExpense {
  id         Int            @id @default(autoincrement())
  year       Int
  month      Int
  categoryId Int
  category   BudgetCategory @relation(fields: [categoryId], references: [id])
  amount     BigInt
  memo       String?
  createdAt  DateTime       @default(now())
}
